@model IReadOnlyList<CategoryViewModel>
@{
    ViewData["Title"] = "Categories";
}

<h2 class="mb-3">Categories</h2>

@if (TempData["SuccessMessage"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p class="mb-3">
    <a class="btn btn-primary" asp-action="Create">Create category</a>
</p>

@if (Model.Count == 0)
{
    <p class="text-muted">No categories yet.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Created</th>
                    <th>Created by</th>
                    <th>Updated</th>
                    <th>Updated by</th>
                    <th class="text-end" style="width: 1%;">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@(item.Description ?? "—")</td>
                    <td>@item.CreatedAt.ToLocalTime().ToString("g")</td>
                    <td>@item.CreatedBy</td>
                    <td>@(item.UpdatedAt.HasValue ? item.UpdatedAt.Value.ToLocalTime().ToString("g") : "—")</td>
                    <td>@(item.UpdatedBy?.ToString() ?? "—")</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Details</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
