@model ProductViewModel
@{
    ViewData["Title"] = "Delete product";
}

<h2 class="mb-3">Delete product</h2>

<p class="text-danger">Are you sure you want to delete this product? This cannot be undone.</p>

@if (!string.IsNullOrEmpty(Model.ImagePath))
{
    <div class="mb-3">
        <img src="~/@Model.ImagePath" alt="@Model.Name" class="img-thumbnail" style="max-height: 120px;" />
    </div>
}

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Category</dt>
    <dd class="col-sm-9">@Model.CategoryName</dd>

    <dt class="col-sm-3">Price</dt>
    <dd class="col-sm-9">@Model.Price.ToString("C")</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@(Model.Description ?? "—")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
</form>
